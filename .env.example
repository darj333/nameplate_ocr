# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

# PostgreSQL connection string (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nameplate_ocr

# Groq API key — get a free key at https://console.groq.com/
GROQ_API_KEY=gsk_...

# Groq model to use for structuring (default: llama-3.3-70b-versatile)
# Other good free options: llama-3.1-8b-instant (faster/lighter), mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Groq vision model — used to read nameplate images directly (no local OCR needed)
GROQ_VISION_MODEL=qwen/qwen3.6-27b

# Directory where uploaded images are stored (Railway Volume is mounted at /data)
UPLOAD_DIR=/data/uploads

# Maximum upload file size in megabytes
MAX_UPLOAD_SIZE_MB=20
